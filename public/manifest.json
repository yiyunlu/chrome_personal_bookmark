{
  "manifest_version": 3,
  "name": "TabHub",
  "description": "A Toby-style new tab experience powered by Chrome native bookmarks.",
  "version": "0.1.0",
  "permissions": ["bookmarks", "tabs", "storage", "favicon"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "TabHub"
  }
}
